c:[["$","h1",null,{"className":"text-4xl font-bold mt-8 mb-4","children":"Corporate Tech Delivery: Building Systems Built to Last"}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","children":"Enterprise technology isn't just about writing code. It's about understanding business requirements, regulatory constraints, and the operational realities of running a corporation at scale."}],"\n",["$","h2",null,{"className":"text-3xl font-bold mt-8 mb-4","children":"What Distinguishes Enterprise Tech?"}],"\n",["$","h3",null,{"className":"text-2xl font-bold mt-6 mb-3","children":["1. ",["$","strong",null,{"children":"Security First"}]]}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","children":"Every enterprise system handles sensitive data. Security can't be an afterthought—it's the foundation. Our approach includes:"}],"\n",["$","ul",null,{"className":"list-disc list-inside mb-4 space-y-2 text-zinc-700 dark:text-zinc-300","children":["\n",["$","li",null,{"className":"ml-4","children":"Zero-trust architecture"}],"\n",["$","li",null,{"className":"ml-4","children":"Encryption at rest and in transit"}],"\n",["$","li",null,{"className":"ml-4","children":"Compliance with standards (ISO, SOC 2, GDPR)"}],"\n",["$","li",null,{"className":"ml-4","children":"Regular penetration testing"}],"\n"]}],"\n",["$","h3",null,{"className":"text-2xl font-bold mt-6 mb-3","children":["2. ",["$","strong",null,{"children":"Reliability and Uptime"}]]}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","children":"A failed system can cost thousands per minute. We build with redundancy, monitoring, and disaster recovery:"}],"\n",["$","ul",null,{"className":"list-disc list-inside mb-4 space-y-2 text-zinc-700 dark:text-zinc-300","children":["\n",["$","li",null,{"className":"ml-4","children":"99.9% uptime SLA"}],"\n",["$","li",null,{"className":"ml-4","children":"Multi-region deployment"}],"\n",["$","li",null,{"className":"ml-4","children":"Automated backups"}],"\n",["$","li",null,{"className":"ml-4","children":"Incident response playbooks"}],"\n"]}],"\n",["$","h3",null,{"className":"text-2xl font-bold mt-6 mb-3","children":["3. ",["$","strong",null,{"children":"Scalability"}]]}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","children":"Your system must grow with your business. We design for scale from day one:"}],"\n",["$","ul",null,{"className":"list-disc list-inside mb-4 space-y-2 text-zinc-700 dark:text-zinc-300","children":["\n",["$","li",null,{"className":"ml-4","children":"Horizontal scaling architecture"}],"\n",["$","li",null,{"className":"ml-4","children":"Load balancing"}],"\n",["$","li",null,{"className":"ml-4","children":"Database optimization"}],"\n",["$","li",null,{"className":"ml-4","children":"CDN for global distribution"}],"\n"]}],"\n",["$","h3",null,{"className":"text-2xl font-bold mt-6 mb-3","children":["4. ",["$","strong",null,{"children":"Compliance and Audit"}]]}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","children":"Enterprises operate in regulated environments. Our systems include:"}],"\n",["$","ul",null,{"className":"list-disc list-inside mb-4 space-y-2 text-zinc-700 dark:text-zinc-300","children":["\n",["$","li",null,{"className":"ml-4","children":"Comprehensive audit trails"}],"\n",["$","li",null,{"className":"ml-4","children":"Compliance reporting"}],"\n",["$","li",null,{"className":"ml-4","children":"Data residency controls"}],"\n",["$","li",null,{"className":"ml-4","children":"Change management workflows"}],"\n"]}],"\n",["$","h2",null,{"className":"text-3xl font-bold mt-8 mb-4","children":"Our Delivery Process"}],"\n",["$","ol",null,{"className":"list-decimal list-inside mb-4 space-y-2 text-zinc-700 dark:text-zinc-300","children":["\n",["$","li",null,{"className":"ml-4","children":[["$","strong",null,{"children":"Discovery"}]," - Understand your business, constraints, and goals"]}],"\n",["$","li",null,{"className":"ml-4","children":[["$","strong",null,{"children":"Architecture"}]," - Design a system that scales and endures"]}],"\n",["$","li",null,{"className":"ml-4","children":[["$","strong",null,{"children":"Development"}]," - Build with best practices and rigorous testing"]}],"\n",["$","li",null,{"className":"ml-4","children":[["$","strong",null,{"children":"Security Review"}]," - Penetration testing and compliance validation"]}],"\n",["$","li",null,{"className":"ml-4","children":[["$","strong",null,{"children":"Deployment"}]," - Careful rollout with monitoring and rollback plans"]}],"\n",["$","li",null,{"className":"ml-4","children":[["$","strong",null,{"children":"Support"}]," - Ongoing maintenance and optimization"]}],"\n"]}],"\n",["$","h2",null,{"className":"text-3xl font-bold mt-8 mb-4","children":"Example: Payment Processing System"}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","children":"We recently deployed a payment processing system for a financial services client that handles 10,000+ transactions daily. The system includes:"}],"\n",["$","ul",null,{"className":"list-disc list-inside mb-4 space-y-2 text-zinc-700 dark:text-zinc-300","children":["\n",["$","li",null,{"className":"ml-4","children":"Real-time transaction monitoring"}],"\n",["$","li",null,{"className":"ml-4","children":"Fraud detection"}],"\n",["$","li",null,{"className":"ml-4","children":"Compliance reporting for RBI standards"}],"\n",["$","li",null,{"className":"ml-4","children":"99.99% uptime in production"}],"\n"]}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","children":"Result: Zero transaction errors, 100% audit readiness."}],"\n",["$","h2",null,{"className":"text-3xl font-bold mt-8 mb-4","children":"The Difference"}],"\n",["$","p",null,{"className":"text-lg leading-7 mb-4 text-zinc-700 dark:text-zinc-300","childre