generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  role          String    @default("user")
  tier          String    @default("normal")
  emailVerified DateTime?
  image         String?
  companyName   String?
  phone         String?
  fullName      String?
  dob           DateTime?
  aadhaarNumber String?
  panNumber     String?
  documentsVerified Boolean @default(false)
  profileComplete Boolean @default(false)
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  subscription  Subscription?
  quota         Quota?
  subscriptionHistory SubscriptionHistory[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model EmailOTP {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String
  expires   DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  badgeText   String
  createdAt   DateTime @default(now())

  // Backward-compatible fields (used by existing orders / admin code)
  itemName    String?  @map("itemName")
  hsnSac      String?  @map("hsnSac")
  rate        Float?   @map("rate")
  gst         Float?   @map("gst")
  status      String?  @default("Active")

  orders      Order[]
}


model Order {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId       String
  razorpayOrderId String   @unique
  paymentStatus   String   @default("Pending")
  createdAt       DateTime @default(now())
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tier               String   @default("normal")  // "normal" | "pro" | "premium"
  status             String   @default("active")  // "active" | "paused" | "cancelled"
  
  razorpayPlanId     String?
  razorpaySubId      String?  @unique
  
  billingCycle       String   @default("monthly")  // "monthly" | "yearly"
  price              Float    @default(0)
  
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextBillingDate    DateTime?
  
  cancellationDate   DateTime?
  cancellationReason String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Quota {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  requestsUsed       Int      @default(0)
  requestsLimit      Int      @default(100)
  
  resetDate          DateTime?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SubscriptionHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  fromTier     String
  toTier       String
  reason       String   // "upgrade" | "downgrade" | "signup" | "cancelled"
  
  createdAt    DateTime @default(now())
}
